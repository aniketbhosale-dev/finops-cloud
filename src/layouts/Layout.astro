---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const { 
	title = "CloudScale - Multi-Cloud Cost Optimization Platform",
	description = "Enterprise-grade FinOps platform to analyze, optimize, and forecast cloud spending across AWS, Microsoft Azure, and GCP."
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
		
		<!-- Inline script to prevent theme flash -->
		<script is:inline>
			const getThemePreference = () => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
			};
			
			const isDark = getThemePreference() === 'dark';
			document.documentElement.classList.toggle('dark', isDark);
		</script>
	</head>
	<body class="bg-slate-50 text-slate-800 dark:bg-[#0B0F19] dark:text-slate-200 min-h-screen font-sans selection:bg-indigo-500/30 selection:text-indigo-900 dark:selection:text-indigo-200">
		<slot />
	</body>
</html>
