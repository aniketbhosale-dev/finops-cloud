---
import EChart from './Charts/EChart.astro';
---

<div id="dashboard-view" class="hidden space-y-6 animate-fade-in pb-16">
  <!-- Header Bar -->
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 bg-white/60 dark:bg-[#111827]/60 backdrop-blur-md border border-slate-200/50 dark:border-slate-800/40 rounded-2xl p-5 shadow-sm no-print">
    <div>
      <div class="flex items-center space-x-3">
        <span class="px-2 py-0.5 text-[9px] font-bold rounded-md uppercase tracking-wider" id="report-provider-pill">-</span>
        <h2 class="text-sm font-bold font-display text-slate-800 dark:text-slate-100" id="report-title-label">Billing Report Analysis</h2>
      </div>
      <p class="text-[10px] text-slate-400 dark:text-slate-500 mt-0.5">
        Source: <span id="report-filename" class="font-medium text-slate-600 dark:text-slate-400">billing.csv</span>
      </p>
    </div>
    <div class="flex flex-wrap gap-2 w-full sm:w-auto">
      <button id="export-pdf" class="flex-1 sm:flex-none px-4 py-2 bg-slate-900 hover:bg-slate-800 text-white dark:bg-slate-100 dark:hover:bg-slate-200 dark:text-slate-900 text-[10px] font-semibold rounded-xl flex items-center justify-center space-x-2 transition-all hover-scale">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
        <span>Export PDF</span>
      </button>
      <button id="export-json" class="flex-1 sm:flex-none px-4 py-2 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 hover:bg-slate-50 dark:hover:bg-slate-800 text-slate-700 dark:text-slate-300 text-[10px] font-semibold rounded-xl flex items-center justify-center space-x-2 transition-all hover-scale">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
        <span>JSON</span>
      </button>
      <button id="reset-btn" class="px-4 py-2 bg-rose-50 hover:bg-rose-100/70 text-rose-600 dark:bg-rose-950/20 dark:hover:bg-rose-950/40 dark:text-rose-400 text-[10px] font-semibold rounded-xl flex items-center justify-center space-x-2 transition-all">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
        <span>Reset</span>
      </button>
    </div>
  </div>

  <!-- Tab Navigation Bar -->
  <div class="flex gap-1 bg-white/60 dark:bg-[#111827]/60 backdrop-blur-md border border-slate-200/50 dark:border-slate-800/40 rounded-2xl p-1.5 no-print overflow-x-auto" id="dashboard-tabs">
    <button class="px-4 py-2 text-[10px] font-bold font-display rounded-xl transition-all whitespace-nowrap bg-indigo-500 text-white shadow-sm" data-tab="overview">Overview</button>
    <button class="px-4 py-2 text-[10px] font-bold font-display rounded-xl transition-all whitespace-nowrap text-slate-500 hover:text-slate-800 dark:text-slate-400 dark:hover:text-slate-100 hover:bg-slate-100 dark:hover:bg-slate-800" data-tab="breakdown">Breakdown</button>
    <button class="px-4 py-2 text-[10px] font-bold font-display rounded-xl transition-all whitespace-nowrap text-slate-500 hover:text-slate-800 dark:text-slate-400 dark:hover:text-slate-100 hover:bg-slate-100 dark:hover:bg-slate-800" data-tab="anomalies">Anomalies &amp; Hidden</button>
    <button class="px-4 py-2 text-[10px] font-bold font-display rounded-xl transition-all whitespace-nowrap text-slate-500 hover:text-slate-800 dark:text-slate-400 dark:hover:text-slate-100 hover:bg-slate-100 dark:hover:bg-slate-800" data-tab="recommendations">Recommendations</button>
    <button class="px-4 py-2 text-[10px] font-bold font-display rounded-xl transition-all whitespace-nowrap text-slate-500 hover:text-slate-800 dark:text-slate-400 dark:hover:text-slate-100 hover:bg-slate-100 dark:hover:bg-slate-800" data-tab="forecast">Forecast</button>
  </div>

  <!-- TAB: Overview -->
  <div class="tab-content space-y-6" id="tab-overview" data-tab-content="overview">
    <!-- Trend Chart + Service Donut -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <div class="lg:col-span-2 bg-white/60 dark:bg-[#111827]/60 backdrop-blur-md border border-slate-200/50 dark:border-slate-800/40 rounded-2xl p-5">
        <div class="flex justify-between items-center mb-4">
          <div>
            <h3 class="text-sm font-bold font-display text-slate-800 dark:text-slate-100">Daily Cost Trend</h3>
            <p class="text-[10px] text-slate-400 dark:text-slate-500">Cost progression over billing cycle</p>
          </div>
          <div class="flex bg-slate-100 dark:bg-slate-800 rounded-xl p-0.5 text-[10px] font-semibold no-print">
            <button class="px-3 py-1 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-100 shadow-sm rounded-lg" id="chart-trend-area">Area</button>
            <button class="px-3 py-1 text-slate-500 hover:text-slate-800 dark:text-slate-400" id="chart-trend-bar">Bar</button>
          </div>
        </div>
        <EChart id="trend-chart" style="height: 300px;" />
      </div>
      <div class="bg-white/60 dark:bg-[#111827]/60 backdrop-blur-md border border-slate-200/50 dark:border-slate-800/40 rounded-2xl p-5">
        <h3 class="text-sm font-bold font-display text-slate-800 dark:text-slate-100">Service Allocation</h3>
        <p class="text-[10px] text-slate-400 dark:text-slate-500 mb-2">Breakdown by cloud service</p>
        <EChart id="service-chart" style="height: 300px;" />
      </div>
    </div>

    <!-- Quick Anomaly + Hidden panels -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- Anomaly Quick Panel -->
      <div class="bg-white/60 dark:bg-[#111827]/60 backdrop-blur-md border border-slate-200/50 dark:border-slate-800/40 rounded-2xl p-5 space-y-4">
        <div class="flex justify-between items-center border-b border-slate-200/50 dark:border-slate-800/40 pb-3">
          <div class="flex items-center">
            <svg class="w-4 h-4 text-rose-500 mr-2 animate-pulse" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path></svg>
            <span class="text-sm font-bold font-display text-slate-800 dark:text-slate-100">Anomalies</span>
          </div>
          <span class="px-2 py-0.5 text-[9px] font-bold rounded-md" id="anomaly-count-pill">0 Alerts</span>
        </div>
        <div class="space-y-2 overflow-y-auto max-h-[260px] no-scrollbar" id="anomalies-list">
          <div class="text-center py-8 text-slate-400 dark:text-slate-600 text-[10px]">No cost anomalies detected.</div>
        </div>
      </div>
      <!-- Hidden Costs Quick Panel -->
      <div class="bg-white/60 dark:bg-[#111827]/60 backdrop-blur-md border border-slate-200/50 dark:border-slate-800/40 rounded-2xl p-5 space-y-4">
        <div class="flex justify-between items-center border-b border-slate-200/50 dark:border-slate-800/40 pb-3">
          <div class="flex items-center">
            <svg class="w-4 h-4 text-amber-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
            <span class="text-sm font-bold font-display text-slate-800 dark:text-slate-100">Hidden Costs</span>
          </div>
          <span class="px-2 py-0.5 text-[9px] font-bold text-slate-700 bg-slate-100 dark:text-slate-300 dark:bg-slate-800 rounded-md" id="hidden-costs-sum">$0</span>
        </div>
        <div class="space-y-2 overflow-y-auto max-h-[260px] no-scrollbar" id="hidden-costs-list">
          <div class="text-center py-8 text-slate-400 dark:text-slate-600 text-[10px]">No hidden fees flagged.</div>
        </div>
      </div>
    </div>
  </div>

  <!-- TAB: Breakdown -->
  <div class="tab-content hidden space-y-6" id="tab-breakdown" data-tab-content="breakdown">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="bg-white/60 dark:bg-[#111827]/60 backdrop-blur-md border border-slate-200/50 dark:border-slate-800/40 rounded-2xl p-5">
        <h3 class="text-sm font-bold font-display text-slate-800 dark:text-slate-100 mb-1">Regional Distribution</h3>
        <p class="text-[10px] text-slate-400 dark:text-slate-500 mb-3">Spending across cloud regions</p>
        <EChart id="region-chart" style="height: 300px;" />
      </div>
      <div class="bg-white/60 dark:bg-[#111827]/60 backdrop-blur-md border border-slate-200/50 dark:border-slate-800/40 rounded-2xl p-5">
        <h3 class="text-sm font-bold font-display text-slate-800 dark:text-slate-100 mb-1">Environment Allocation</h3>
        <p class="text-[10px] text-slate-400 dark:text-slate-500 mb-3">Spend by environment</p>
        <EChart id="environment-chart" style="height: 300px;" />
      </div>
    </div>
    <!-- Cost Breakdown Table -->
    <div class="bg-white/60 dark:bg-[#111827]/60 backdrop-blur-md border border-slate-200/50 dark:border-slate-800/40 rounded-2xl p-5">
      <h3 class="text-sm font-bold font-display text-slate-800 dark:text-slate-100 mb-3">Top Cost Drivers</h3>
      <div class="overflow-x-auto">
        <table class="w-full text-left">
          <thead>
            <tr class="border-b border-slate-200/50 dark:border-slate-800/40">
              <th class="text-[9px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-wider py-2 px-3">Service</th>
              <th class="text-[9px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-wider py-2 px-3 text-right">Cost</th>
              <th class="text-[9px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-wider py-2 px-3 text-right">% of Total</th>
            </tr>
          </thead>
          <tbody id="cost-breakdown-table"></tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- TAB: Anomalies & Hidden -->
  <div class="tab-content hidden space-y-6" id="tab-anomalies" data-tab-content="anomalies">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- Full Anomalies -->
      <div class="bg-white/60 dark:bg-[#111827]/60 backdrop-blur-md border border-slate-200/50 dark:border-slate-800/40 rounded-2xl p-5 space-y-4">
        <div class="flex justify-between items-center border-b border-slate-200/50 dark:border-slate-800/40 pb-3">
          <div class="flex items-center">
            <svg class="w-4 h-4 text-rose-500 mr-2 animate-pulse" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path></svg>
            <span class="text-sm font-bold font-display text-slate-800 dark:text-slate-100">Cost Anomaly Detection</span>
          </div>
          <span class="px-2 py-0.5 text-[9px] font-bold text-rose-600 bg-rose-50 dark:text-rose-400 dark:bg-rose-950/30 rounded-md" id="anomaly-count-pill-full">0 Alerts</span>
        </div>
        <div class="space-y-2 overflow-y-auto max-h-[480px] no-scrollbar" id="anomalies-list-full">
          <div class="text-center py-12 text-slate-400 dark:text-slate-600 text-[10px]">No cost anomalies detected.</div>
        </div>
      </div>
      <!-- Full Hidden Costs -->
      <div class="bg-white/60 dark:bg-[#111827]/60 backdrop-blur-md border border-slate-200/50 dark:border-slate-800/40 rounded-2xl p-5 space-y-4">
        <div class="flex justify-between items-center border-b border-slate-200/50 dark:border-slate-800/40 pb-3">
          <div class="flex items-center">
            <svg class="w-4 h-4 text-amber-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
            <span class="text-sm font-bold font-display text-slate-800 dark:text-slate-100">Hidden Charges Audit</span>
          </div>
          <span class="px-2 py-0.5 text-[9px] font-bold text-slate-700 bg-slate-100 dark:text-slate-300 dark:bg-slate-800 rounded-md" id="hidden-costs-sum-full">$0</span>
        </div>
        <div class="space-y-2 overflow-y-auto max-h-[480px] no-scrollbar" id="hidden-costs-list-full">
          <div class="text-center py-12 text-slate-400 dark:text-slate-600 text-[10px]">No hidden fees flagged.</div>
        </div>
      </div>
    </div>
  </div>

  <!-- TAB: Recommendations -->
  <div class="tab-content hidden space-y-6" id="tab-recommendations" data-tab-content="recommendations">
    <div class="bg-white/60 dark:bg-[#111827]/60 backdrop-blur-md border border-slate-200/50 dark:border-slate-800/40 rounded-2xl p-5 space-y-4">
      <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3 border-b border-slate-200/50 dark:border-slate-800/40 pb-3">
        <div>
          <h3 class="text-sm font-bold font-display text-slate-800 dark:text-slate-100">Cost Optimization Proposals</h3>
          <p class="text-[10px] text-slate-400 dark:text-slate-500">Actionable strategies to reduce waste</p>
        </div>
        <input type="text" id="rec-search-input" placeholder="Filter recommendations..." class="px-3 py-1.5 bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 text-[10px] rounded-xl focus:outline-none focus:border-indigo-500 dark:focus:border-indigo-400 w-full sm:w-48 no-print" />
      </div>
      <div class="flex flex-wrap gap-1.5 text-[10px] font-semibold no-print" id="rec-tabs">
        <button class="px-3 py-1 bg-indigo-500 text-white rounded-xl shadow-sm" data-category="All">All</button>
        <button class="px-3 py-1 bg-slate-50 hover:bg-slate-100 dark:bg-slate-900 dark:hover:bg-slate-800 text-slate-600 dark:text-slate-400 rounded-xl" data-category="Compute">Compute</button>
        <button class="px-3 py-1 bg-slate-50 hover:bg-slate-100 dark:bg-slate-900 dark:hover:bg-slate-800 text-slate-600 dark:text-slate-400 rounded-xl" data-category="Storage">Storage</button>
        <button class="px-3 py-1 bg-slate-50 hover:bg-slate-100 dark:bg-slate-900 dark:hover:bg-slate-800 text-slate-600 dark:text-slate-400 rounded-xl" data-category="Networking">Network</button>
        <button class="px-3 py-1 bg-slate-50 hover:bg-slate-100 dark:bg-slate-900 dark:hover:bg-slate-800 text-slate-600 dark:text-slate-400 rounded-xl" data-category="Database">Database</button>
        <button class="px-3 py-1 bg-slate-50 hover:bg-slate-100 dark:bg-slate-900 dark:hover:bg-slate-800 text-slate-600 dark:text-slate-400 rounded-xl" data-category="Kubernetes">K8s</button>
        <button class="px-3 py-1 bg-slate-50 hover:bg-slate-100 dark:bg-slate-900 dark:hover:bg-slate-800 text-slate-600 dark:text-slate-400 rounded-xl" data-category="Serverless">Serverless</button>
        <button class="px-3 py-1 bg-slate-50 hover:bg-slate-100 dark:bg-slate-900 dark:hover:bg-slate-800 text-slate-600 dark:text-slate-400 rounded-xl" data-category="Security">Security</button>
      </div>
      <div class="space-y-3 max-h-[520px] overflow-y-auto pr-2 no-scrollbar" id="recommendations-container"></div>
    </div>
  </div>

  <!-- TAB: Forecast -->
  <div class="tab-content hidden space-y-6" id="tab-forecast" data-tab-content="forecast">
    <!-- Forecast Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6" id="forecasts-cards-grid"></div>
    <!-- Resource Health -->
    <div class="bg-white/60 dark:bg-[#111827]/60 backdrop-blur-md border border-slate-200/50 dark:border-slate-800/40 rounded-2xl p-5 space-y-4">
      <div>
        <h3 class="text-sm font-bold font-display text-slate-800 dark:text-slate-100">Resource Lifecycle Health</h3>
        <p class="text-[10px] text-slate-400 dark:text-slate-500">State audit for zombie, idle, and oversized resources</p>
      </div>
      <div class="grid grid-cols-3 gap-4 pb-4 border-b border-slate-200/50 dark:border-slate-800/40">
        <div class="bg-rose-50/50 dark:bg-rose-950/10 p-3 rounded-xl">
          <span class="text-rose-500 dark:text-rose-400 text-xl font-bold font-display" id="zombie-count">0</span>
          <p class="text-[9px] font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider mt-0.5">Zombies</p>
        </div>
        <div class="bg-amber-50/50 dark:bg-amber-950/10 p-3 rounded-xl">
          <span class="text-amber-500 dark:text-amber-400 text-xl font-bold font-display" id="idle-count">0</span>
          <p class="text-[9px] font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider mt-0.5">Idle</p>
        </div>
        <div class="bg-indigo-50/50 dark:bg-indigo-950/10 p-3 rounded-xl">
          <span class="text-indigo-500 dark:text-indigo-400 text-xl font-bold font-display" id="underutilized-count">0</span>
          <p class="text-[9px] font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider mt-0.5">Underutilized</p>
        </div>
      </div>
      <div class="space-y-2 overflow-y-auto max-h-[360px] no-scrollbar" id="health-items-list"></div>
    </div>
  </div>
</div>

<script>
  import type { AnalysisResults, Recommendation, Anomaly, ResourceDetail, Forecast } from '../lib/types';

  let currentData: AnalysisResults | null = null;
  let activeCategoryFilter = 'All';
  let activeSearchQuery = '';

  const fmt = (val: number) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(val);
  const fmtCompact = (val: number) => {
    if (val >= 1000) return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', notation: 'compact', maximumFractionDigits: 1 }).format(val);
    return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(val);
  };

  // ── Tab Switching ──────────────────────────────────────────────
  function initTabs() {
    const tabButtons = document.querySelectorAll('#dashboard-tabs button');
    tabButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const tabId = btn.getAttribute('data-tab');
        if (!tabId) return;
        // Update button styles
        tabButtons.forEach(b => {
          b.className = 'px-4 py-2 text-[10px] font-bold font-display rounded-xl transition-all whitespace-nowrap text-slate-500 hover:text-slate-800 dark:text-slate-400 dark:hover:text-slate-100 hover:bg-slate-100 dark:hover:bg-slate-800';
        });
        btn.className = 'px-4 py-2 text-[10px] font-bold font-display rounded-xl transition-all whitespace-nowrap bg-indigo-500 text-white shadow-sm';
        // Show/hide tab content
        document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
        const target = document.getElementById('tab-' + tabId);
        if (target) target.classList.remove('hidden');
      });
    });
  }
  initTabs();

  // ── Main Data Handler ──────────────────────────────────────────
  window.addEventListener('report-processed', (e: Event) => {
    const customEvent = e as CustomEvent<{ data: AnalysisResults; filename: string }>;
    const { data, filename } = customEvent.detail;
    currentData = data;

    const dashboardView = document.getElementById('dashboard-view');
    dashboardView?.classList.remove('hidden');

    // Provider pill
    const pill = document.getElementById('report-provider-pill');
    if (pill) {
      pill.textContent = data.provider.toUpperCase();
      pill.className = 'px-2 py-0.5 text-[9px] font-bold rounded-md uppercase tracking-wider ';
      if (data.provider === 'aws') pill.classList.add('text-orange-700', 'bg-orange-100', 'dark:text-orange-400', 'dark:bg-orange-950/50');
      else if (data.provider === 'azure') pill.classList.add('text-blue-700', 'bg-blue-100', 'dark:text-blue-400', 'dark:bg-blue-950/50');
      else if (data.provider === 'gcp') pill.classList.add('text-blue-700', 'bg-blue-100', 'dark:text-blue-400', 'dark:bg-blue-950/50');
    }

    const filenameEl = document.getElementById('report-filename');
    if (filenameEl) filenameEl.textContent = filename;

    // Render all sections
    renderDailyTrendChart();
    renderServiceAllocationChart();
    renderRegionalChart();
    renderEnvironmentChart();
    renderAnomalies(data.anomalies);
    renderHiddenCosts(data.hiddenCosts);
    renderCostBreakdownTable();
    renderRecommendations();
    renderHealthStatus(data.resourceHealth);
    renderForecasts(data.forecasts);
  });

  // ── Reset Handler ──────────────────────────────────────────────
  window.addEventListener('reset-dashboard', () => {
    currentData = null;
    activeCategoryFilter = 'All';
    activeSearchQuery = '';

    window.destroyChart('trend-chart');
    window.destroyChart('service-chart');
    window.destroyChart('region-chart');
    window.destroyChart('environment-chart');

    // Clear lists
    ['anomalies-list', 'anomalies-list-full', 'hidden-costs-list', 'hidden-costs-list-full', 'recommendations-container', 'forecasts-cards-grid', 'health-items-list', 'cost-breakdown-table'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.innerHTML = '';
    });

    // Reset pills/sums
    ['hidden-costs-sum', 'hidden-costs-sum-full'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.textContent = '$0';
    });
    ['anomaly-count-pill', 'anomaly-count-pill-full'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.textContent = '0 Alerts';
    });
    ['zombie-count', 'idle-count', 'underutilized-count'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.textContent = '0';
    });

    // Reset tabs back to Overview
    const tabButtons = document.querySelectorAll('#dashboard-tabs button');
    tabButtons.forEach(b => {
      b.className = 'px-4 py-2 text-[10px] font-bold font-display rounded-xl transition-all whitespace-nowrap text-slate-500 hover:text-slate-800 dark:text-slate-400 dark:hover:text-slate-100 hover:bg-slate-100 dark:hover:bg-slate-800';
    });
    const overviewBtn = document.querySelector('#dashboard-tabs button[data-tab="overview"]');
    if (overviewBtn) overviewBtn.className = 'px-4 py-2 text-[10px] font-bold font-display rounded-xl transition-all whitespace-nowrap bg-indigo-500 text-white shadow-sm';
    document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
    const overviewTab = document.getElementById('tab-overview');
    if (overviewTab) overviewTab.classList.remove('hidden');
  });

  // ── Trend Chart ────────────────────────────────────────────────
  let currentTrendChartType = 'area';

  function renderDailyTrendChart() {
    if (!currentData) return;
    const dailySpend = currentData.dailySpend;
    const sortedDates = Object.keys(dailySpend).sort();
    const costs = sortedDates.map(d => Math.round(dailySpend[d] * 100) / 100);
    const isArea = currentTrendChartType === 'area';

    const options = {
      tooltip: { trigger: 'axis', axisPointer: { type: 'line' } },
      grid: { left: '3%', right: '4%', bottom: '3%', containLabel: true },
      xAxis: {
        type: 'category',
        data: sortedDates.map(d => d.substring(5)),
        axisLine: { lineStyle: { color: '#64748b' } }
      },
      yAxis: {
        type: 'value',
        name: 'Spend ($)',
        splitLine: { lineStyle: { type: 'dashed', color: 'rgba(148, 163, 184, 0.1)' } }
      },
      series: [{
        name: 'Daily Cost',
        type: isArea ? 'line' : 'bar',
        smooth: true,
        itemStyle: { color: '#6366f1' },
        areaStyle: isArea ? {
          color: {
            type: 'linear', x: 0, y: 0, x2: 0, y2: 1,
            colorStops: [
              { offset: 0, color: 'rgba(99, 102, 241, 0.35)' },
              { offset: 1, color: 'rgba(99, 102, 241, 0)' }
            ]
          }
        } : undefined,
        data: costs
      }]
    };

    window.initChart('trend-chart', options);
  }

  const btnArea = document.getElementById('chart-trend-area');
  const btnBar = document.getElementById('chart-trend-bar');

  btnArea?.addEventListener('click', () => {
    currentTrendChartType = 'area';
    btnArea.className = 'px-3 py-1 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-100 shadow-sm rounded-lg';
    if (btnBar) btnBar.className = 'px-3 py-1 text-slate-500 hover:text-slate-800 dark:text-slate-400';
    renderDailyTrendChart();
  });

  btnBar?.addEventListener('click', () => {
    currentTrendChartType = 'bar';
    btnBar.className = 'px-3 py-1 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-100 shadow-sm rounded-lg';
    if (btnArea) btnArea.className = 'px-3 py-1 text-slate-500 hover:text-slate-800 dark:text-slate-400';
    renderDailyTrendChart();
  });

  // ── Service Donut Chart ────────────────────────────────────────
  function renderServiceAllocationChart() {
    if (!currentData) return;
    const services = currentData.breakdown.service;
    const data = Object.entries(services)
      .map(([name, value]) => ({ name, value: Math.round(value) }))
      .sort((a, b) => b.value - a.value);

    const options = {
      series: [{
        name: 'Service Spend',
        type: 'pie',
        radius: ['42%', '68%'],
        center: ['50%', '50%'],
        avoidLabelOverlap: true,
        padAngle: 3,
        itemStyle: { borderRadius: 8 },
        label: { show: false, position: 'center' },
        emphasis: {
          label: { show: true, fontSize: 12, fontWeight: 'bold', formatter: '{b}\n{d}%' }
        },
        data
      }]
    };

    window.initChart('service-chart', options);
  }

  // ── Regional Treemap Chart ─────────────────────────────────────
  function renderRegionalChart() {
    if (!currentData) return;
    const regions = currentData.breakdown.region;
    const data = Object.entries(regions)
      .map(([name, value]) => ({ name, value: Math.round(value) }))
      .sort((a, b) => b.value - a.value);

    const options = {
      tooltip: { trigger: 'item' },
      series: [{
        name: 'Region',
        type: 'treemap',
        visibleMinArea: 300,
        label: { show: true, formatter: '{b}\n${c}' },
        upperLabel: { show: false },
        itemStyle: { borderWidth: 1, borderColor: 'rgba(255,255,255,0.1)' },
        levels: [{ itemStyle: { borderGapWidth: 2, gapWidth: 2 } }],
        data
      }]
    };

    window.initChart('region-chart', options);
  }

  // ── Environment Bar Chart ──────────────────────────────────────
  function renderEnvironmentChart() {
    if (!currentData) return;
    const envs = currentData.breakdown.environment;
    const rawKeys = Object.keys(envs);
    const rawVals = Object.values(envs).map(v => Math.round(v));

    const options = {
      grid: { left: '3%', right: '4%', bottom: '3%', top: '5%', containLabel: true },
      xAxis: {
        type: 'value',
        splitLine: { lineStyle: { type: 'dashed', color: 'rgba(148, 163, 184, 0.1)' } }
      },
      yAxis: {
        type: 'category',
        data: rawKeys,
        axisLine: { lineStyle: { color: '#64748b' } }
      },
      series: [{
        name: 'Spend',
        type: 'bar',
        barWidth: '50%',
        itemStyle: { color: '#10b981', borderRadius: [0, 4, 4, 0] },
        data: rawVals
      }]
    };

    window.initChart('environment-chart', options);
  }

  // ── Anomaly Rendering ──────────────────────────────────────────
  function renderAnomalies(anomalies: Anomaly[]) {
    const list = document.getElementById('anomalies-list');
    const listFull = document.getElementById('anomalies-list-full');
    const countPill = document.getElementById('anomaly-count-pill');
    const countPillFull = document.getElementById('anomaly-count-pill-full');

    const buildAnomalyCard = (anom: Anomaly) => {
      const card = document.createElement('div');
      card.className = 'p-3 border rounded-xl flex flex-col space-y-1.5 transition-all duration-200 hover:bg-slate-50/50 dark:hover:bg-slate-900/40';

      if (anom.severity === 'high') {
        card.classList.add('border-rose-100', 'bg-rose-50/15', 'dark:border-rose-950/40', 'dark:bg-rose-950/10');
      } else if (anom.severity === 'medium') {
        card.classList.add('border-amber-100', 'bg-amber-50/15', 'dark:border-amber-950/40', 'dark:bg-amber-950/10');
      } else {
        card.classList.add('border-slate-200', 'bg-slate-50/10', 'dark:border-slate-800', 'dark:bg-slate-900/10');
      }

      const badgeColor = anom.severity === 'high' ? 'bg-rose-500' : anom.severity === 'medium' ? 'bg-amber-500' : 'bg-slate-400';

      card.innerHTML = `
        <div class="flex justify-between items-start">
          <div class="flex items-center space-x-2">
            <span class="w-2 h-2 rounded-full ${badgeColor}"></span>
            <span class="text-[10px] font-bold text-slate-700 dark:text-slate-300 uppercase">${anom.service}</span>
          </div>
          <span class="text-[9px] font-bold text-slate-400 dark:text-slate-500">${anom.date}</span>
        </div>
        <p class="text-[10px] text-slate-600 dark:text-slate-300 leading-relaxed">${anom.description}</p>
        <div class="flex justify-between items-center text-[9px] text-slate-400 dark:text-slate-500 pt-1">
          <span>Region: <b class="text-slate-600 dark:text-slate-300">${anom.region}</b></span>
          <span class="text-slate-700 dark:text-slate-300">Spike: <b class="text-rose-500 dark:text-rose-400">+${anom.percentageSpike}%</b></span>
        </div>`;
      return card;
    };

    if (list) {
      list.innerHTML = '';
      if (anomalies.length === 0) {
        list.innerHTML = '<div class="text-center py-8 text-slate-400 dark:text-slate-600 text-[10px]">No cost anomalies detected.</div>';
      } else {
        anomalies.forEach(a => list.appendChild(buildAnomalyCard(a)));
      }
    }

    if (listFull) {
      listFull.innerHTML = '';
      if (anomalies.length === 0) {
        listFull.innerHTML = '<div class="text-center py-12 text-slate-400 dark:text-slate-600 text-[10px]">No cost anomalies detected.</div>';
      } else {
        anomalies.forEach(a => listFull.appendChild(buildAnomalyCard(a)));
      }
    }

    const updatePill = (el: HTMLElement | null, count: number) => {
      if (!el) return;
      el.textContent = `${count} Alert${count === 1 ? '' : 's'}`;
      if (count > 0) {
        el.className = 'px-2 py-0.5 text-[9px] font-bold rounded-md text-rose-600 bg-rose-50 dark:text-rose-400 dark:bg-rose-950/30 animate-pulse';
      } else {
        el.className = 'px-2 py-0.5 text-[9px] font-bold rounded-md text-slate-500 bg-slate-50 dark:text-slate-400 dark:bg-slate-800';
      }
    };
    updatePill(countPill, anomalies.length);
    updatePill(countPillFull, anomalies.length);
  }

  // ── Hidden Costs Rendering ─────────────────────────────────────
  function renderHiddenCosts(hiddenCosts: any[]) {
    const list = document.getElementById('hidden-costs-list');
    const listFull = document.getElementById('hidden-costs-list-full');
    const sumEl = document.getElementById('hidden-costs-sum');
    const sumFullEl = document.getElementById('hidden-costs-sum-full');

    const grouped: Record<string, { service: string; cost: number; details: string }> = {};
    let totalHidden = 0;

    hiddenCosts.forEach(h => {
      totalHidden += h.cost;
      if (!grouped[h.category]) {
        grouped[h.category] = { service: h.service, cost: 0, details: h.details };
      }
      grouped[h.category].cost += h.cost;
      grouped[h.category].service = h.service;
    });

    const totalStr = `${fmt(totalHidden)} hidden`;
    if (sumEl) sumEl.textContent = totalStr;
    if (sumFullEl) sumFullEl.textContent = `${fmt(totalHidden)} hidden fees`;

    const buildHiddenRow = (category: string, data: { service: string; cost: number; details: string }) => {
      const row = document.createElement('div');
      row.className = 'p-3 bg-white dark:bg-slate-900 border border-slate-200/50 dark:border-slate-800 rounded-xl flex items-center justify-between transition-all duration-200 hover:shadow-sm';
      row.innerHTML = `
        <div class="space-y-0.5 flex-1 pr-4">
          <div class="flex items-center space-x-2">
            <h4 class="text-[10px] font-bold text-slate-700 dark:text-slate-200">${category}</h4>
            <span class="text-[8px] px-1.5 py-0.5 bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 rounded-md font-semibold">${data.service}</span>
          </div>
          <p class="text-[9px] text-slate-400 dark:text-slate-500 leading-normal">${data.details}</p>
        </div>
        <div class="text-right flex-shrink-0">
          <span class="text-[11px] font-bold text-slate-800 dark:text-slate-100">${fmt(data.cost)}</span>
        </div>`;
      return row;
    };

    const sortedCategories = Object.entries(grouped).sort((a, b) => b[1].cost - a[1].cost);

    const populateList = (container: HTMLElement | null) => {
      if (!container) return;
      container.innerHTML = '';
      if (hiddenCosts.length === 0) {
        container.innerHTML = '<div class="text-center py-12 text-slate-400 dark:text-slate-600 text-[10px]">No hidden fees flagged.</div>';
        return;
      }
      sortedCategories.forEach(([category, data]) => {
        container.appendChild(buildHiddenRow(category, data));
      });
    };

    populateList(list);
    populateList(listFull);
  }

  // ── Cost Breakdown Table ───────────────────────────────────────
  function renderCostBreakdownTable() {
    const tbody = document.getElementById('cost-breakdown-table');
    if (!tbody || !currentData) return;
    tbody.innerHTML = '';

    const services = currentData.breakdown.service;
    const total = Object.values(services).reduce((s, v) => s + v, 0);
    const sorted = Object.entries(services).sort((a, b) => b[1] - a[1]).slice(0, 12);

    sorted.forEach(([name, cost]) => {
      const pct = total > 0 ? ((cost / total) * 100).toFixed(1) : '0';
      const tr = document.createElement('tr');
      tr.className = 'border-b border-slate-100 dark:border-slate-800/50 hover:bg-slate-50/50 dark:hover:bg-slate-900/30 transition-colors';
      tr.innerHTML = `
        <td class="text-[10px] font-semibold text-slate-700 dark:text-slate-300 py-2 px-3">${name}</td>
        <td class="text-[10px] font-bold text-slate-800 dark:text-slate-100 py-2 px-3 text-right">${fmt(cost)}</td>
        <td class="py-2 px-3 text-right">
          <div class="flex items-center justify-end space-x-2">
            <div class="w-16 h-1.5 bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden">
              <div class="h-full bg-indigo-500 rounded-full" style="width: ${pct}%"></div>
            </div>
            <span class="text-[9px] font-semibold text-slate-500 dark:text-slate-400 w-8 text-right">${pct}%</span>
          </div>
        </td>`;
      tbody.appendChild(tr);
    });
  }

  // ── Recommendation Rendering ───────────────────────────────────
  function renderRecommendations() {
    const container = document.getElementById('recommendations-container');
    if (!container || !currentData) return;
    container.innerHTML = '';

    const recs = currentData.recommendations;

    const filtered = recs.filter(rec => {
      const categoryMatches = activeCategoryFilter === 'All' || rec.category === activeCategoryFilter;
      const searchMatches = activeSearchQuery === '' ||
        rec.title.toLowerCase().includes(activeSearchQuery.toLowerCase()) ||
        rec.description.toLowerCase().includes(activeSearchQuery.toLowerCase()) ||
        rec.category.toLowerCase().includes(activeSearchQuery.toLowerCase());
      return categoryMatches && searchMatches;
    });

    if (filtered.length === 0) {
      container.innerHTML = '<div class="text-center py-16 text-slate-400 dark:text-slate-600 text-[10px]">No recommendations match your filters.</div>';
      return;
    }

    filtered.forEach(rec => {
      const card = document.createElement('div');
      card.className = 'p-4 bg-white dark:bg-slate-900 border border-slate-200/50 dark:border-slate-800 rounded-2xl space-y-3 hover:shadow-md transition-shadow duration-300';

      const impactColor = rec.impact === 'high'
        ? 'bg-rose-50 text-rose-600 dark:bg-rose-950/20 dark:text-rose-400'
        : rec.impact === 'medium'
          ? 'bg-amber-50 text-amber-600 dark:bg-amber-950/20 dark:text-amber-400'
          : 'bg-slate-50 text-slate-600 dark:bg-slate-800 dark:text-slate-400';
      const effortColor = rec.effort === 'easy' ? 'text-emerald-500' : rec.effort === 'moderate' ? 'text-amber-500' : 'text-rose-500';
      const catColor = rec.category === 'Compute' ? 'bg-indigo-50 text-indigo-600 dark:bg-indigo-950/20 dark:text-indigo-400'
        : rec.category === 'Storage' ? 'bg-purple-50 text-purple-600 dark:bg-purple-950/20 dark:text-purple-400'
        : rec.category === 'Networking' ? 'bg-cyan-50 text-cyan-600 dark:bg-cyan-950/20 dark:text-cyan-400'
        : rec.category === 'Database' ? 'bg-emerald-50 text-emerald-600 dark:bg-emerald-950/20 dark:text-emerald-400'
        : rec.category === 'Kubernetes' ? 'bg-blue-50 text-blue-600 dark:bg-blue-950/20 dark:text-blue-400'
        : rec.category === 'Serverless' ? 'bg-violet-50 text-violet-600 dark:bg-violet-950/20 dark:text-violet-400'
        : 'bg-slate-50 text-slate-600 dark:bg-slate-800 dark:text-slate-400';

      const stepsHtml = rec.actionableSteps.map(step => `
        <li class="flex items-start text-[10px] text-slate-500 dark:text-slate-400 leading-relaxed">
          <svg class="w-3 h-3 mr-1.5 text-indigo-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4"></path></svg>
          ${step}
        </li>`).join('');

      const recId = 'rec-steps-' + rec.id.replace(/[^a-zA-Z0-9]/g, '');

      card.innerHTML = `
        <div class="flex justify-between items-start gap-3">
          <div class="space-y-1">
            <div class="flex flex-wrap items-center gap-1.5">
              <span class="px-1.5 py-0.5 text-[8px] font-bold uppercase rounded ${catColor}">${rec.category}</span>
              <span class="px-1.5 py-0.5 text-[8px] font-bold uppercase rounded ${impactColor}">Impact: ${rec.impact}</span>
            </div>
            <h4 class="text-[11px] font-bold text-slate-800 dark:text-slate-100 pt-1">${rec.title}</h4>
            <p class="text-[10px] text-slate-500 dark:text-slate-400 leading-relaxed">${rec.description}</p>
          </div>
          <div class="text-right flex-shrink-0">
            <span class="text-sm font-extrabold text-emerald-500 dark:text-emerald-400">${fmt(rec.potentialSavings)}<span class="text-[8px] font-normal text-slate-400 block">/mo savings</span></span>
          </div>
        </div>
        <div class="bg-slate-50/50 dark:bg-slate-950/20 rounded-xl p-3 space-y-2 cursor-pointer rec-expand-area" data-target="${recId}">
          <div class="flex items-center justify-between">
            <span class="text-[9px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-wider">Action Plan (Effort: <span class="${effortColor}">${rec.effort.toUpperCase()}</span>)</span>
            <svg class="w-3 h-3 text-slate-400 transition-transform rec-chevron" data-target="${recId}" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </div>
          <ul class="space-y-1 rec-steps hidden" id="${recId}">${stepsHtml}</ul>
        </div>`;

      container.appendChild(card);
    });

    // Expandable action steps
    container.querySelectorAll('.rec-expand-area').forEach(area => {
      area.addEventListener('click', () => {
        const targetId = area.getAttribute('data-target');
        if (!targetId) return;
        const stepsEl = document.getElementById(targetId);
        const chevron = area.querySelector('.rec-chevron');
        if (stepsEl) {
          stepsEl.classList.toggle('hidden');
          if (chevron) {
            chevron.style.transform = stepsEl.classList.contains('hidden') ? '' : 'rotate(180deg)';
          }
        }
      });
    });
  }

  // Recommendation filter tabs
  const recTabs = document.querySelectorAll('#rec-tabs button');
  recTabs.forEach(tab => {
    tab.addEventListener('click', () => {
      recTabs.forEach(t => {
        t.className = 'px-3 py-1 bg-slate-50 hover:bg-slate-100 dark:bg-slate-900 dark:hover:bg-slate-800 text-slate-600 dark:text-slate-400 rounded-xl';
      });
      tab.className = 'px-3 py-1 bg-indigo-500 text-white rounded-xl shadow-sm';
      activeCategoryFilter = tab.getAttribute('data-category') || 'All';
      renderRecommendations();
    });
  });

  // Recommendation search
  const recSearch = document.getElementById('rec-search-input') as HTMLInputElement;
  recSearch?.addEventListener('input', () => {
    activeSearchQuery = recSearch.value;
    renderRecommendations();
  });

  // ── Health Status Rendering ────────────────────────────────────
  function renderHealthStatus(health: any) {
    const list = document.getElementById('health-items-list');
    const zCount = document.getElementById('zombie-count');
    const iCount = document.getElementById('idle-count');
    const uCount = document.getElementById('underutilized-count');

    if (zCount) zCount.textContent = String(health.zombie.length);
    if (iCount) iCount.textContent = String(health.idle.length);
    if (uCount) uCount.textContent = String(health.underutilized.length);

    if (!list) return;
    list.innerHTML = '';

    const allItems: ResourceDetail[] = [...health.zombie, ...health.idle, ...health.underutilized];

    if (allItems.length === 0) {
      list.innerHTML = '<div class="text-center py-12 text-slate-400 dark:text-slate-600 text-[10px]">All resources active and optimized.</div>';
      return;
    }

    allItems.forEach(item => {
      const row = document.createElement('div');
      row.className = 'p-3 border border-slate-200/50 dark:border-slate-800 bg-white dark:bg-slate-900 rounded-xl flex flex-col space-y-1 transition-all duration-200 hover:shadow-sm';

      const badgeStyle = item.status === 'zombie'
        ? 'bg-rose-50 text-rose-500 dark:bg-rose-950/20 dark:text-rose-400'
        : item.status === 'idle'
          ? 'bg-amber-50 text-amber-500 dark:bg-amber-950/20 dark:text-amber-400'
          : 'bg-indigo-50 text-indigo-500 dark:bg-indigo-950/20 dark:text-indigo-400';

      row.innerHTML = `
        <div class="flex justify-between items-start">
          <div class="space-y-0.5">
            <h4 class="text-[10px] font-bold text-slate-700 dark:text-slate-200 truncate max-w-[200px]" title="${item.id}">${item.name}</h4>
            <span class="text-[8px] text-slate-400 dark:text-slate-500">${item.type} &bull; <b>${item.id.substring(0, 12)}</b></span>
          </div>
          <span class="px-1.5 py-0.5 text-[8px] font-bold rounded uppercase tracking-wider ${badgeStyle}">${item.status}</span>
        </div>
        <p class="text-[9px] text-slate-500 dark:text-slate-400 leading-normal border-t border-slate-100 dark:border-slate-800 pt-1">${item.metric}</p>
        <div class="flex justify-between items-center text-[9px] pt-1">
          <span class="text-slate-400 dark:text-slate-500">Provider: <b class="text-slate-600 dark:text-slate-300">${item.provider.toUpperCase()}</b></span>
          <span class="font-semibold text-slate-700 dark:text-slate-300">Cost: <b>${fmt(item.cost)}/mo</b></span>
        </div>`;
      list.appendChild(row);
    });
  }

  // ── Forecast Rendering ─────────────────────────────────────────
  function renderForecasts(forecasts: Forecast[]) {
    const grid = document.getElementById('forecasts-cards-grid');
    if (!grid) return;
    grid.innerHTML = '';

    forecasts.forEach(f => {
      const card = document.createElement('div');
      card.className = 'bg-white/60 dark:bg-[#111827]/60 backdrop-blur-md border border-slate-200/50 dark:border-slate-800/40 rounded-2xl p-5 relative overflow-hidden transition-all duration-300 hover:shadow-md';

      const label = f.period === 'EOM' ? 'End of Month' : f.period === 'EOQ' ? 'End of Quarter' : 'End of Year';
      const indicatorColor = f.confidence >= 85 ? 'bg-emerald-500' : f.confidence >= 70 ? 'bg-amber-500' : 'bg-slate-400';

      card.innerHTML = `
        <div class="space-y-3">
          <div class="flex justify-between items-center">
            <span class="text-[10px] font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-wider">${label}</span>
            <div class="flex items-center space-x-1.5 text-[9px] font-semibold text-slate-500">
              <span class="w-1.5 h-1.5 rounded-full ${indicatorColor}"></span>
              <span>Conf: ${f.confidence}%</span>
            </div>
          </div>
          <h4 class="text-xl font-bold font-display text-slate-800 dark:text-slate-100">${fmt(f.predictedCost)}</h4>
          <div class="flex justify-between items-center text-[9px] text-slate-400 dark:text-slate-500 border-t border-slate-100 dark:border-slate-800/80 pt-2.5">
            <span>95% range:</span>
            <span class="font-medium text-slate-600 dark:text-slate-300">${fmt(f.lowerBound)} — ${fmt(f.upperBound)}</span>
          </div>
        </div>`;
      grid.appendChild(card);
    });
  }

  // ── Export JSON ────────────────────────────────────────────────
  document.getElementById('export-json')?.addEventListener('click', () => {
    if (!currentData) return;
    const blob = new Blob([JSON.stringify(currentData, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `finops-report-${currentData.provider}-${new Date().toISOString().split('T')[0]}.json`;
    a.click();
    URL.revokeObjectURL(url);
  });

  // ── Export PDF (print) ─────────────────────────────────────────
  document.getElementById('export-pdf')?.addEventListener('click', () => {
    window.print();
  });

  // ── Reset Button ───────────────────────────────────────────────
  document.getElementById('reset-btn')?.addEventListener('click', () => {
    window.dispatchEvent(new Event('reset-dashboard'));
    const dashboardView = document.getElementById('dashboard-view');
    dashboardView?.classList.add('hidden');
    const uploadArea = document.getElementById('upload-area-container');
    if (uploadArea) uploadArea.classList.remove('hidden');
  });
</script>

<style>
  @media print {
    body { background: white !important; color: black !important; padding: 0 !important; }
    .no-print { display: none !important; }
    #dashboard-view { display: block !important; padding: 0 !important; }
    .echart-container { page-break-inside: avoid; }
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fadeIn 0.4s ease-out forwards;
  }
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>
