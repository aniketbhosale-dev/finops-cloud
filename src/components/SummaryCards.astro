---
// SummaryCards.astro - Executive cost overview with key metrics
---

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4" id="summary-cards-container">
  <!-- Total Monthly Spend - Hero Card -->
  <div class="sm:col-span-2 glass-panel rounded-3xl p-6 relative overflow-hidden transition-all duration-300 hover:shadow-lg border border-slate-200/60 dark:border-slate-800/60">
    <div class="flex justify-between items-start">
      <div class="space-y-3">
        <div class="flex items-center space-x-2">
          <p class="text-xs font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-wider">
            Monthly Spend
          </p>
          <span class="px-2 py-0.5 text-[9px] font-bold rounded-md uppercase tracking-wider" id="provider-pill">-</span>
        </div>
        <h3 class="text-4xl font-extrabold font-display text-slate-900 dark:text-white tracking-tight" id="mtd-cost">
          $0
        </h3>
        <div class="flex items-center space-x-4 text-xs">
          <span class="text-slate-500 dark:text-slate-400">Daily avg: <span class="font-semibold text-slate-700 dark:text-slate-300" id="daily-avg">$0</span></span>
          <span class="text-slate-500 dark:text-slate-400">Records: <span class="font-semibold text-slate-700 dark:text-slate-300" id="record-count">0</span></span>
        </div>
      </div>
      <div class="p-3 bg-indigo-50 dark:bg-indigo-950/40 text-indigo-500 rounded-2xl">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
    </div>
    <div class="absolute bottom-0 right-0 opacity-[0.04] pointer-events-none -z-10 translate-x-6 translate-y-6">
      <svg width="120" height="120" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="60" cy="60" r="50" stroke="currentColor" stroke-width="12"></circle>
        <path d="M60 10 A50 50 0 0 1 110 60" stroke="currentColor" stroke-width="12" stroke-linecap="round"></path>
      </svg>
    </div>
  </div>

  <!-- Budget Utilization -->
  <div class="glass-panel rounded-3xl p-5 relative overflow-hidden transition-all duration-300 hover:shadow-lg">
    <div class="space-y-3">
      <div class="flex items-center justify-between">
        <p class="text-[10px] font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-wider">Budget</p>
        <div class="p-2 bg-amber-50 dark:bg-amber-950/40 text-amber-500 rounded-xl" id="budget-icon-container">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
          </svg>
        </div>
      </div>
      <div>
        <span class="text-2xl font-extrabold font-display text-slate-800 dark:text-slate-100" id="budget-percent">0%</span>
        <span class="text-[10px] text-slate-400 dark:text-slate-500 ml-1">utilized</span>
      </div>
      <div class="text-[10px] text-slate-400 dark:text-slate-500">
        of <span class="font-semibold text-slate-600 dark:text-slate-400" id="budget-limit">$0</span> limit
      </div>
      <div class="w-full bg-slate-100 dark:bg-slate-800/80 h-1.5 rounded-full overflow-hidden">
        <div class="h-full rounded-full transition-all duration-700 ease-out" id="budget-progress-bar" style="width: 0%"></div>
      </div>
    </div>
  </div>

  <!-- EOM Forecast -->
  <div class="glass-panel rounded-3xl p-5 relative overflow-hidden transition-all duration-300 hover:shadow-lg">
    <div class="space-y-3">
      <div class="flex items-center justify-between">
        <p class="text-[10px] font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-wider">EOM Forecast</p>
        <div class="p-2 bg-purple-50 dark:bg-purple-950/40 text-purple-500 rounded-xl">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
          </svg>
        </div>
      </div>
      <div>
        <span class="text-2xl font-extrabold font-display text-slate-800 dark:text-slate-100" id="eom-forecast">$0</span>
      </div>
      <div class="flex items-center space-x-1.5 text-[10px] text-slate-400 dark:text-slate-500">
        <svg class="w-3 h-3 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
        <span>Confidence: <span class="font-semibold text-slate-600 dark:text-slate-400" id="forecast-confidence">0%</span></span>
      </div>
    </div>
  </div>

  <!-- FinOps Score -->
  <div class="glass-panel rounded-3xl p-5 relative overflow-hidden transition-all duration-300 hover:shadow-lg">
    <div class="space-y-3">
      <div class="flex items-center justify-between">
        <p class="text-[10px] font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-wider">FinOps Score</p>
        <div class="p-2 bg-emerald-50 dark:bg-emerald-950/40 rounded-xl" id="score-icon-container">
          <svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        </div>
      </div>
      <div>
        <span class="text-3xl font-extrabold font-display" id="finops-score-num">0</span>
        <span class="text-[10px] text-slate-400 dark:text-slate-500 ml-1">/100</span>
      </div>
      <span class="text-[10px] font-bold uppercase tracking-wider" id="finops-grade">-</span>
    </div>
  </div>

  <!-- Potential Savings -->
  <div class="sm:col-span-2 lg:col-span-1 glass-panel rounded-3xl p-5 relative overflow-hidden transition-all duration-300 hover:shadow-lg">
    <div class="space-y-3">
      <div class="flex items-center justify-between">
        <p class="text-[10px] font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-wider">Est. Savings</p>
        <div class="p-2 bg-emerald-50 dark:bg-emerald-950/40 text-emerald-500 rounded-xl">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
        </div>
      </div>
      <div>
        <span class="text-2xl font-extrabold font-display text-emerald-600 dark:text-emerald-400" id="savings-est">$0</span>
        <span class="text-[10px] text-slate-400 dark:text-slate-500 ml-1">/mo</span>
      </div>
      <div class="text-[10px] text-slate-400 dark:text-slate-500">
        <span class="font-semibold text-slate-600 dark:text-slate-400" id="rec-count">0</span> recommendations
      </div>
    </div>
  </div>
</div>

<script>
  import type { AnalysisResults } from '../lib/types';

  const fmt = (val: number) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(val);
  const fmtCompact = (val: number) => {
    if (val >= 1000) return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', notation: 'compact', maximumFractionDigits: 1 }).format(val);
    return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(val);
  };

  window.addEventListener('report-processed', (e: Event) => {
    const customEvent = e as CustomEvent<{ data: AnalysisResults }>;
    const data = customEvent.detail.data;

    // 1. Total spend hero
    const mtdCostEl = document.getElementById('mtd-cost');
    if (mtdCostEl) mtdCostEl.textContent = fmt(data.currentMonthSpend);

    // Daily average
    const dailyAvgEl = document.getElementById('daily-avg');
    if (dailyAvgEl) {
      const days = Object.keys(data.dailySpend).length || 1;
      dailyAvgEl.textContent = fmtCompact(data.currentMonthSpend / days);
    }

    // Record count (from breakdown)
    const recordCountEl = document.getElementById('record-count');
    if (recordCountEl) {
      const totalRecords = Object.values(data.breakdown.service).reduce((s, v) => s + v, 0) > 0 ? '-' : '0';
      recordCountEl.textContent = Object.keys(data.dailySpend).length + ' days';
    }

    // Provider pill
    const providerPill = document.getElementById('provider-pill');
    if (providerPill) {
      const labels: Record<string, string> = { aws: 'AWS', azure: 'Azure', gcp: 'GCP' };
      providerPill.textContent = labels[data.provider] || data.provider.toUpperCase();
      providerPill.className = 'px-2 py-0.5 text-[9px] font-bold rounded-md uppercase tracking-wider ';
      if (data.provider === 'aws') providerPill.classList.add('text-orange-700', 'bg-orange-100', 'dark:text-orange-400', 'dark:bg-orange-950/50');
      else if (data.provider === 'azure') providerPill.classList.add('text-blue-700', 'bg-blue-100', 'dark:text-blue-400', 'dark:bg-blue-950/50');
      else if (data.provider === 'gcp') providerPill.classList.add('text-blue-700', 'bg-blue-100', 'dark:text-blue-400', 'dark:bg-blue-950/50');
    }

    // 2. Budget utilization
    const budgetPercentEl = document.getElementById('budget-percent');
    const budgetLimitEl = document.getElementById('budget-limit');
    const budgetProgress = document.getElementById('budget-progress-bar');
    const budgetIcon = document.getElementById('budget-icon-container');

    if (budgetPercentEl && budgetLimitEl && budgetProgress) {
      const util = data.budgetUtilization;
      budgetPercentEl.textContent = `${Math.round(util)}%`;
      budgetLimitEl.textContent = fmt(data.budgetLimit);
      budgetProgress.style.width = `${Math.min(util, 100)}%`;

      budgetProgress.className = 'h-full rounded-full transition-all duration-700 ease-out ';
      if (util > 95) {
        budgetProgress.classList.add('bg-rose-500');
        if (budgetIcon) budgetIcon.className = 'p-2 bg-rose-50 dark:bg-rose-950/40 text-rose-500 rounded-xl';
      } else if (util > 75) {
        budgetProgress.classList.add('bg-amber-500');
        if (budgetIcon) budgetIcon.className = 'p-2 bg-amber-50 dark:bg-amber-950/40 text-amber-500 rounded-xl';
      } else {
        budgetProgress.classList.add('bg-indigo-500');
        if (budgetIcon) budgetIcon.className = 'p-2 bg-indigo-50 dark:bg-indigo-950/40 text-indigo-500 rounded-xl';
      }
    }

    // 3. EOM Forecast
    const eomForecastEl = document.getElementById('eom-forecast');
    const forecast = data.forecasts.find(f => f.period === 'EOM');
    if (eomForecastEl && forecast) {
      eomForecastEl.textContent = fmt(forecast.predictedCost);
      const confLabel = document.getElementById('forecast-confidence');
      if (confLabel) confLabel.textContent = `${forecast.confidence}%`;
    }

    // 4. FinOps Score
    const finopsEl = document.getElementById('finops-score-num');
    const finopsGrade = document.getElementById('finops-grade');
    const scoreIcon = document.getElementById('score-icon-container');
    if (finopsEl && finopsGrade) {
      const score = data.finopsScore;
      finopsEl.textContent = String(score);
      finopsEl.className = 'text-3xl font-extrabold font-display ';

      if (score >= 90) {
        finopsEl.classList.add('text-emerald-500', 'dark:text-emerald-400');
        finopsGrade.textContent = 'Excellent';
        finopsGrade.className = 'text-[10px] font-bold text-emerald-500 uppercase tracking-wider';
        if (scoreIcon) scoreIcon.className = 'p-2 bg-emerald-50 dark:bg-emerald-950/40 rounded-xl';
      } else if (score >= 70) {
        finopsEl.classList.add('text-amber-500', 'dark:text-amber-400');
        finopsGrade.textContent = 'Healthy';
        finopsGrade.className = 'text-[10px] font-bold text-amber-500 uppercase tracking-wider';
        if (scoreIcon) scoreIcon.className = 'p-2 bg-amber-50 dark:bg-amber-950/40 rounded-xl';
      } else {
        finopsEl.classList.add('text-rose-500', 'dark:text-rose-400');
        finopsGrade.textContent = 'Action Required';
        finopsGrade.className = 'text-[10px] font-bold text-rose-500 uppercase tracking-wider';
        if (scoreIcon) scoreIcon.className = 'p-2 bg-rose-50 dark:bg-rose-950/40 rounded-xl';
      }
    }

    // 5. Savings
    const savingsEstEl = document.getElementById('savings-est');
    if (savingsEstEl) {
      const totalSavings = data.recommendations.reduce((sum, r) => sum + r.potentialSavings, 0);
      savingsEstEl.textContent = fmtCompact(totalSavings);
    }
    const recCountEl = document.getElementById('rec-count');
    if (recCountEl) recCountEl.textContent = String(data.recommendations.length);
  });

  window.addEventListener('reset-dashboard', () => {
    const ids = ['mtd-cost', 'eom-forecast', 'budget-percent', 'budget-limit', 'finops-score-num', 'savings-est', 'daily-avg', 'forecast-confidence'];
    ids.forEach(id => {
      const el = document.getElementById(id);
      if (el) {
        if (id === 'mtd-cost' || id === 'eom-forecast' || id === 'budget-limit') el.textContent = '$0';
        else if (id === 'daily-avg') el.textContent = '$0';
        else el.textContent = '0';
      }
    });
    const bar = document.getElementById('budget-progress-bar');
    if (bar) bar.style.width = '0%';
  });
</script>
