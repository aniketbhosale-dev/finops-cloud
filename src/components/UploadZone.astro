---
// UploadZone.astro - Cloud provider selector + CSV uploader + demo data loader
---

<div class="w-full max-w-4xl mx-auto">
  <!-- Drop Zone -->
  <div
    id="drop-zone"
    class="relative group cursor-pointer border-2 border-dashed border-slate-300 dark:border-slate-700 hover:border-indigo-500 dark:hover:border-indigo-400 rounded-3xl p-12 text-center transition-all duration-300 bg-white/50 dark:bg-[#111827]/50 backdrop-blur-xl hover:shadow-[0_0_50px_-12px_rgba(99,102,241,0.25)]"
  >
    <input type="file" id="file-input" class="hidden" accept=".csv" />

    <div class="flex flex-col items-center justify-center space-y-4">
      <div class="absolute -inset-px rounded-3xl bg-gradient-to-r from-indigo-500 to-violet-500 opacity-0 group-hover:opacity-5 transition-opacity duration-500 -z-10"></div>

      <div class="p-4 bg-indigo-50 dark:bg-indigo-950/40 text-indigo-500 rounded-2xl group-hover:scale-110 transition-transform duration-300">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.233-2.33 3 3 0 013.758 3.848A3.752 3.752 0 0118 19.5H6.75z" />
        </svg>
      </div>

      <div>
        <h3 class="text-xl font-semibold font-display text-slate-800 dark:text-slate-200">
          Upload billing reports
        </h3>
        <p class="text-sm text-slate-500 dark:text-slate-400 mt-1 max-w-sm mx-auto">
          Drag & drop your AWS, Azure, or GCP billing CSV here, or click to browse.
        </p>
        <p id="selected-provider-label" class="text-xs text-indigo-600 dark:text-indigo-400 mt-2 font-semibold hidden">
          Provider: <span id="selected-provider"></span>
        </p>
      </div>

      <div class="flex items-center space-x-6 text-xs text-slate-400 dark:text-slate-500 border-t border-slate-200/50 dark:border-slate-800/50 pt-4 w-full justify-center">
        <span class="flex items-center">
          <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          AWS Cost & Usage
        </span>
        <span class="flex items-center">
          <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          Azure Usage Details
        </span>
        <span class="flex items-center">
          <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          GCP Detailed Export
        </span>
      </div>
    </div>
  </div>

  <!-- Loading Screen -->
  <div id="upload-loading" class="hidden my-8 p-8 border border-indigo-100 dark:border-indigo-900/30 bg-indigo-50/30 dark:bg-indigo-950/10 rounded-2xl">
    <div class="flex items-center space-x-4">
      <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-indigo-600 dark:border-indigo-400"></div>
      <div class="flex-1">
        <h4 class="font-semibold text-slate-800 dark:text-slate-200">Analyzing billing records...</h4>
        <div class="w-full bg-slate-200 dark:bg-slate-800 h-1.5 rounded-full mt-2 overflow-hidden">
          <div class="bg-indigo-600 dark:bg-indigo-400 h-full rounded-full animate-[pulse_1.5s_infinite]" style="width: 70%"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Error Panel -->
  <div id="upload-error" class="hidden my-6 p-4 border border-rose-200 bg-rose-50 dark:border-rose-950/30 dark:bg-rose-950/20 text-rose-800 dark:text-rose-300 text-sm rounded-2xl flex items-center space-x-3">
    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
    <span id="error-message">Error processing file.</span>
  </div>

  <!-- Sample data Quick Loader -->
  <div class="mt-8 text-center space-y-4">
    <div class="flex items-center justify-center space-x-4">
      <div class="h-px bg-slate-200 dark:bg-slate-800 w-16"></div>
      <span class="text-xs font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-wider">
        No files? Try one-click demo
      </span>
      <div class="h-px bg-slate-200 dark:bg-slate-800 w-16"></div>
    </div>

    <div class="flex flex-wrap justify-center gap-3">
      <button
        type="button"
        data-provider="aws"
        class="demo-btn px-5 py-2.5 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 hover:border-orange-500 dark:hover:border-orange-500/50 hover:bg-orange-50/20 dark:hover:bg-orange-950/10 text-slate-700 dark:text-slate-300 text-xs font-semibold rounded-xl flex items-center space-x-2 transition-all hover-scale"
      >
        <span class="w-2.5 h-2.5 rounded-full bg-brand-aws animate-pulse"></span>
        <span>AWS Cloud Demo</span>
      </button>

      <button
        type="button"
        data-provider="azure"
        class="demo-btn px-5 py-2.5 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 hover:border-blue-500 dark:hover:border-blue-500/50 hover:bg-blue-50/20 dark:hover:bg-blue-950/10 text-slate-700 dark:text-slate-300 text-xs font-semibold rounded-xl flex items-center space-x-2 transition-all hover-scale"
      >
        <span class="w-2.5 h-2.5 rounded-full bg-brand-azure animate-pulse"></span>
        <span>Azure Cloud Demo</span>
      </button>

      <button
        type="button"
        data-provider="gcp"
        class="demo-btn px-5 py-2.5 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 hover:border-blue-600 dark:hover:border-blue-600/50 hover:bg-blue-50/20 dark:hover:bg-blue-950/10 text-slate-700 dark:text-slate-300 text-xs font-semibold rounded-xl flex items-center space-x-2 transition-all hover-scale"
      >
        <span class="w-2.5 h-2.5 rounded-full bg-brand-gcp animate-pulse"></span>
        <span>GCP Cloud Demo</span>
      </button>
    </div>
  </div>
</div>

<!-- Provider Selection Modal -->
<div id="provider-modal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center hidden">
  <div class="bg-white dark:bg-slate-900 rounded-3xl p-8 max-w-md w-full mx-4 shadow-2xl border border-slate-200/50 dark:border-slate-800/50">
    <div class="text-center space-y-6">
      <div class="w-16 h-16 bg-gradient-to-tr from-indigo-500 to-violet-600 rounded-2xl flex items-center justify-center mx-auto">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-white">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 7.5L7.5 3m0 0l4.5 4.5M3 7.5v9a6 6 0 006 6h9a6 6 0 006-6v-9m-9 6l4.5-4.5M21 7.5L16.5 3m0 0l-4.5 4.5M21 7.5v9a6 6 0 01-6 6h-9a6 6 0 01-6-6v-9m6 6h6m-6 3h6" />
        </svg>
      </div>

      <div>
        <h3 class="text-xl font-bold font-display text-slate-800 dark:text-slate-100 mb-2">
          Select Cloud Provider
        </h3>
        <p class="text-sm text-slate-500 dark:text-slate-400">
          Which cloud provider does this billing report belong to?
        </p>
      </div>

      <div class="space-y-3">
        <button
          data-provider="aws"
          class="provider-select-btn w-full p-4 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 hover:border-orange-500 dark:hover:border-orange-500/50 hover:bg-orange-50/20 dark:hover:bg-orange-950/10 text-slate-700 dark:text-slate-300 rounded-xl flex items-center space-x-3 transition-all"
        >
          <span class="w-3 h-3 rounded-full bg-orange-500"></span>
          <span class="font-semibold">AWS (Amazon Web Services)</span>
        </button>

        <button
          data-provider="azure"
          class="provider-select-btn w-full p-4 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 hover:border-blue-500 dark:hover:border-blue-500/50 hover:bg-blue-50/20 dark:hover:bg-blue-950/10 text-slate-700 dark:text-slate-300 rounded-xl flex items-center space-x-3 transition-all"
        >
          <span class="w-3 h-3 rounded-full bg-blue-500"></span>
          <span class="font-semibold">Microsoft Azure</span>
        </button>

        <button
          data-provider="gcp"
          class="provider-select-btn w-full p-4 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 hover:border-blue-600 dark:hover:border-blue-600/50 hover:bg-blue-50/20 dark:hover:bg-blue-950/10 text-slate-700 dark:text-slate-300 rounded-xl flex items-center space-x-3 transition-all"
        >
          <span class="w-3 h-3 rounded-full bg-blue-600"></span>
          <span class="font-semibold">Google Cloud Platform (GCP)</span>
        </button>
      </div>

      <p class="text-xs text-slate-400 dark:text-slate-500">
        This helps us parse your CSV with the correct column mapping
      </p>
    </div>
  </div>
</div>

<script>
  import { generateAWSMock, generateAzureMock, generateGCPMock } from '../lib/mockGenerator';

  const dropZone = document.getElementById('drop-zone');
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const loadingDiv = document.getElementById('upload-loading');
  const errorDiv = document.getElementById('upload-error');
  const errorMessage = document.getElementById('error-message');
  const providerModal = document.getElementById('provider-modal');
  const selectedProviderLabel = document.getElementById('selected-provider-label');
  const selectedProviderEl = document.getElementById('selected-provider');
  const demoButtons = document.querySelectorAll('.demo-btn');
  const providerButtons = document.querySelectorAll('.provider-select-btn');

  let currentProvider: string = '';

  function showProviderModal() {
    providerModal?.classList.remove('hidden');
  }

  function hideProviderModal() {
    providerModal?.classList.add('hidden');
  }

  function showLoading() {
    loadingDiv?.classList.remove('hidden');
    dropZone?.classList.add('pointer-events-none', 'opacity-50');
  }

  function hideLoading() {
    loadingDiv?.classList.add('hidden');
    dropZone?.classList.remove('pointer-events-none', 'opacity-50');
  }

  function showError(msg: string) {
    if (errorMessage && errorDiv) {
      errorMessage.textContent = msg;
      errorDiv.classList.remove('hidden');
    }
  }

  function hideError() {
    errorDiv?.classList.add('hidden');
  }

  async function handleFileUpload(file: File, providerOverride?: string, retryCount = 0): Promise<void> {
    if (!file.name.endsWith('.csv')) {
      showError('Invalid file format. Please upload a CSV billing report.');
      return;
    }

    const providerToUse = (providerOverride || currentProvider).toLowerCase();
    if (!providerToUse) {
      showError('Please select a cloud provider first.');
      return;
    }

    console.log('[UploadZone] provider:', providerToUse, 'file:', file.name, 'attempt:', retryCount + 1);

    showLoading();
    hideError();

    const maxRetries = 2;
    try {
      const formData = new FormData();
      formData.append('file', file);
      formData.append('provider', providerToUse);

      const controller = new AbortController();
      const timeoutId = setTimeout(() => controller.abort(), 60000); // 60s timeout

      const response = await fetch('/api/analyze', {
        method: 'POST',
        body: formData,
        signal: controller.signal,
      });

      clearTimeout(timeoutId);

      const text = await response.text();
      let data;
      try {
        data = JSON.parse(text);
      } catch {
        throw new Error('Invalid response from server. The file may be too large or the server encountered an internal error.');
      }

      if (!response.ok) {
        throw new Error(data.error || `Server error (${response.status}). Please check your CSV format.`);
      }

      if (!data || typeof data !== 'object') {
        throw new Error('Empty or malformed response from server.');
      }

      hideLoading();

      const event = new CustomEvent('report-processed', {
        detail: { data, filename: file.name }
      });
      window.dispatchEvent(event);

    } catch (err: any) {
      console.error('[UploadZone] Error:', err);

      if (err.name === 'AbortError') {
        if (retryCount < maxRetries) {
          showError(`Request timed out. Retrying... (${retryCount + 1}/${maxRetries})`);
          await new Promise(r => setTimeout(r, 1500));
          return handleFileUpload(file, providerOverride, retryCount + 1);
        }
        showError('Request timed out after multiple attempts. The file may be too large. Try a smaller CSV file.');
      } else if (retryCount < maxRetries && (err.message.includes('network') || err.message.includes('Network') || err.message.includes('fetch'))) {
        showError(`Network error. Retrying... (${retryCount + 1}/${maxRetries})`);
        await new Promise(r => setTimeout(r, 1500));
        return handleFileUpload(file, providerOverride, retryCount + 1);
      } else {
        showError(err.message || 'An unexpected error occurred while analyzing the file.');
      }

      hideLoading();
    }
  }

  dropZone?.addEventListener('click', () => {
    if (!currentProvider) {
      showProviderModal();
    } else {
      fileInput?.click();
    }
  });

  dropZone?.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('border-indigo-500', 'bg-indigo-50/10', 'dark:bg-indigo-950/15');
  });

  ['dragleave', 'drop'].forEach(eventName => {
    dropZone?.addEventListener(eventName, () => {
      dropZone.classList.remove('border-indigo-500', 'bg-indigo-50/10', 'dark:bg-indigo-950/15');
    });
  });

  dropZone?.addEventListener('drop', (e: DragEvent) => {
    e.preventDefault();
    if (!currentProvider) {
      showProviderModal();
      return;
    }
    const files = e.dataTransfer?.files;
    if (files && files.length > 0) {
      handleFileUpload(files[0]);
    }
  });

  fileInput?.addEventListener('change', () => {
    if (fileInput.files && fileInput.files.length > 0) {
      handleFileUpload(fileInput.files[0]);
    }
  });

  providerButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const provider = btn.getAttribute('data-provider');
      if (provider) {
        currentProvider = provider.toUpperCase();
        if (selectedProviderEl) selectedProviderEl.textContent = currentProvider;
        if (selectedProviderLabel) selectedProviderLabel.classList.remove('hidden');
      }
      hideProviderModal();
      fileInput?.click();
    });
  });

  providerModal?.addEventListener('click', (e) => {
    if (e.target === providerModal) {
      hideProviderModal();
    }
  });

  demoButtons.forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const provider = btn.getAttribute('data-provider');
      let csvContent = '';
      let filename = '';

      if (provider === 'aws') {
        csvContent = generateAWSMock();
        filename = 'aws-billing.csv';
      } else if (provider === 'azure') {
        csvContent = generateAzureMock();
        filename = 'azure-billing.csv';
      } else if (provider === 'gcp') {
        csvContent = generateGCPMock();
        filename = 'gcp-billing.csv';
      }

      currentProvider = provider?.toUpperCase() || 'AWS';
      const file = new File([csvContent], filename, { type: 'text/csv' });
      handleFileUpload(file, provider);
    });
  });

  window.addEventListener('reset-dashboard', () => {
    hideLoading();
    hideError();
    if (fileInput) fileInput.value = '';
  });
</script>
