---
import Layout from '../layouts/Layout.astro';
import UploadZone from '../components/UploadZone.astro';
import SummaryCards from '../components/SummaryCards.astro';
import DashboardView from '../components/DashboardView.astro';
---

<Layout title="CloudScale - Multi-Cloud Cost Optimization Platform">
  <div class="min-h-screen flex flex-col">
    <!-- Premium Glassmorphic Navbar -->
    <header class="sticky top-0 z-50 w-full border-b border-slate-200/40 dark:border-slate-800/40 bg-white/70 dark:bg-[#0B0F19]/75 backdrop-blur-md transition-colors duration-300 no-print">
      <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
        <!-- Logo -->
        <a href="/" class="flex items-center space-x-2.5 group">
          <div class="w-8 h-8 rounded-xl bg-gradient-to-tr from-indigo-500 to-violet-600 flex items-center justify-center text-white shadow-md shadow-indigo-500/20 group-hover:scale-105 transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" />
            </svg>
          </div>
          <span class="text-lg font-bold font-display text-slate-800 dark:text-slate-100 tracking-tight">
            CloudScale
          </span>
        </a>

        <!-- Navigation / Right elements -->
        <div class="flex items-center space-x-4">
          <!-- Dark Mode Toggle Button -->
          <button 
            id="theme-toggle" 
            type="button" 
            class="p-2.5 rounded-xl border border-slate-200/50 dark:border-slate-800/60 bg-slate-50 hover:bg-slate-100 dark:bg-slate-900/50 dark:hover:bg-slate-800 text-slate-500 dark:text-slate-400 transition-all hover-scale"
            aria-label="Toggle Dark Mode"
          >
            <!-- Sun Icon (shown in dark mode) -->
            <svg id="theme-toggle-light-icon" class="hidden w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707M12 7a5 5 0 100 10 5 5 0 000-10z"></path>
            </svg>
            <!-- Moon Icon (shown in light mode) -->
            <svg id="theme-toggle-dark-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
            </svg>
          </button>
          
          <span class="text-xs px-2.5 py-1.5 font-semibold bg-slate-100 dark:bg-slate-900 text-slate-600 dark:text-slate-400 rounded-xl border border-slate-200/30 dark:border-slate-800/30">
            v1.0.0
          </span>
        </div>
      </div>
    </header>

    <!-- Main Container -->
    <main class="flex-1 max-w-7xl w-full mx-auto px-6 py-12">
      <!-- 1. Landing / Upload Area (Visible initially) -->
      <div id="upload-area-container" class="space-y-12 py-16 animate-fade-in no-print">
        <div class="text-center space-y-4 max-w-2xl mx-auto">
          <span class="px-3.5 py-1.5 text-xs font-bold text-indigo-600 bg-indigo-50 dark:text-indigo-400 dark:bg-indigo-950/40 rounded-full tracking-wide uppercase">
            Platform Engine Active
          </span>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold font-display text-slate-900 dark:text-white leading-[1.1] tracking-tight">
            Analyze & Optimize <span class="bg-clip-text text-transparent bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500">Cloud Spending</span>
          </h1>
          <p class="text-base text-slate-500 dark:text-slate-400 max-w-xl mx-auto leading-relaxed">
            Upload billing files to identify hidden charges, audit resource lifecycles, detect anomalies, and forecast multi-cloud spend across AWS, Azure, and GCP.
          </p>
        </div>

        <UploadZone />
      </div>

      <!-- 2. Dashboard Interface (Hidden initially, shown after load) -->
      <div id="dashboard-container" class="hidden space-y-8 animate-fade-in">
        <SummaryCards />
        <DashboardView />
      </div>
    </main>

    <!-- Footer -->
    <footer class="border-t border-slate-200/50 dark:border-slate-800/40 bg-white/20 dark:bg-[#0B0F19]/20 py-8 no-print">
      <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-slate-400 dark:text-slate-500">
        <p>© 2026 CloudScale FinOps System. Enterprise cost management optimized.</p>
        <div class="flex space-x-6">
          <a href="#" class="hover:text-slate-600 dark:hover:text-slate-300">Privacy Policy</a>
          <a href="#" class="hover:text-slate-600 dark:hover:text-slate-300">Terms of Use</a>
          <a href="#" class="hover:text-slate-600 dark:hover:text-slate-300">Documentation</a>
        </div>
      </div>
    </footer>
  </div>
</Layout>

<script>
  // Theme Toggle Logic
  const themeToggleBtn = document.getElementById('theme-toggle');
  const lightIcon = document.getElementById('theme-toggle-light-icon');
  const darkIcon = document.getElementById('theme-toggle-dark-icon');

  function updateToggleIcons() {
    const isDark = document.documentElement.classList.contains('dark');
    if (isDark) {
      lightIcon?.classList.remove('hidden');
      darkIcon?.classList.add('hidden');
    } else {
      lightIcon?.classList.add('hidden');
      darkIcon?.classList.remove('hidden');
    }
  }

  // Initial Sync
  updateToggleIcons();

  themeToggleBtn?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    updateToggleIcons();
  });

  // Handle successful upload routing
  window.addEventListener('report-processed', () => {
    const landing = document.getElementById('upload-area-container');
    const dashboard = document.getElementById('dashboard-container');
    
    if (landing && dashboard) {
      landing.classList.add('hidden');
      dashboard.classList.remove('hidden');
    }
  });

  // Handle reset routing
  window.addEventListener('reset-dashboard', () => {
    const landing = document.getElementById('upload-area-container');
    const dashboard = document.getElementById('dashboard-container');
    
    if (landing && dashboard) {
      landing.classList.remove('hidden');
      dashboard.classList.add('hidden');
    }
  });
</script>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
</style>
